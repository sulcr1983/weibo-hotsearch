# 汽车行业舆情监控 V4.1 环境配置
# 复制为 .env 并填写真实值

# 数据库路径
DB_PATH=v3_monitor.db
WEIBO_DB_PATH=v3_weibo.db

# 微博热搜配置
#   注意：V4.1 已改用 weibo.com/ajax/side/hotSearch（免Cookie，无需登录）
#   WEIBO_HOTSEARCH_URL 仅作保留，不再实际使用
#   WEIBO_COOKIE 已废弃，保留仅为兼容性
WEIBO_HOTSEARCH_URL=https://s.weibo.com/top/summary
# WEIBO_COOKIE=  (V4.1 不再需要)

# AI API（火山引擎 Ark）
AI_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
AI_API_KEY=你的API_Key
AI_MODEL=doubao-seed-2-0-pro-260215

# 飞书机器人 Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# 邮件配置（QQ邮箱为例）
EMAIL_SENDER=你的邮箱@qq.com
EMAIL_PASSWORD=你的SMTP授权码
EMAIL_RECIPIENTS=收件人1@qq.com,收件人2@qq.com
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587

# RSSHub 地址（Docker 部署时默认）
RSSHUB_HOST=http://localhost:1200
