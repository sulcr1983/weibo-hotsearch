# 数据库配置（相对路径将自动解析到项目根目录）
DATABASE_PATH=weibo_hotsearch.db
V2_DB_PATH=news_articles.db

# 微博热搜配置（必填，否则无法抓取）
WEIBO_COOKIE=your_weibo_cookie_here

# AI API 配置（智谱清言，用于清洗和生成周报分析）
AI_API_KEY=your_ai_api_key_here
AI_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
AI_MODEL=glm-4-flash

# 飞书机器人 Webhook 地址（用于推送消息）
FEISHU_WEBHOOK_URL=your_feishu_webhook_url_here

# 邮件配置（QQ邮箱 SMTP）
EMAIL_SENDER=your_qq_email@qq.com
EMAIL_PASSWORD=your_qq_email_authorization_code_here
EMAIL_RECIPIENTS=recipient@example.com
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
